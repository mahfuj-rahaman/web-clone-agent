PORT="3000"
PROXY_TIMEOUT="30000"
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
ENABLE_LOGGING="true"
CLONES_DIR="/app/clones"

# Full-browser rendering (Camoufox) for JS-heavy / bulky pages.
# 'auto' renders with Camoufox and falls back to plain HTTP fetch on failure;
# 'always' fails the clone if Camoufox is unreachable; 'never' skips rendering.
RENDER_MODE="auto"
RENDER_TIMEOUT_MS="15000"
CAMOUFOX_WS_ENDPOINT="ws://camoufox:9222/camoufox"

DEFAULT_INCLUDE_IMAGES="true"
DEFAULT_REMOVE_SCRIPTS="true"
MAX_IMAGE_SIZE_BYTES="5242880"
INCLUDED_IMAGE_EXTENSIONS="png,jpg,jpeg,gif,svg,webp,ico,avif"
MCP_SERVER_NAME="web-clone-agent"
MCP_SERVER_VERSION="1.0.0"

# Optional: if set, POST /api/clone and DELETE /api/clones/:id require
# header "x-api-key: <value>". Leave unset for open local/dev use.
API_KEY=""
# Max POST /api/clone requests per IP per minute
RATE_LIMIT_PER_MINUTE="10"