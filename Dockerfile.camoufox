FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    xauth \
    libgtk-3-0 \
    libx11-xcb1 \
    libasound2 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir camoufox[geoip]
RUN python -m camoufox fetch

COPY camoufox_server.py entrypoint.sh ./
RUN chmod +x entrypoint.sh

EXPOSE 9222

# Camoufox intentionally avoids true headless mode (detectable), so it needs a
# virtual X display even in a container. `camoufox server` itself takes no CLI
# options (no --port/--host), so camoufox_server.py calls launch_server()
# directly with a fixed host/port for the Node client to connect to.
# entrypoint.sh starts Xvfb directly (xvfb-run's SIGUSR1 readiness handshake
# is unreliable as container PID 1).
CMD ["./entrypoint.sh"]
